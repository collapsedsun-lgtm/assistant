{
  "default_location": "Bristol",
  "local_timezone": "Europe/London",
  "default_temperature_unit": "Celsius",
  "ollama_use_session": true,
  "weather_provider": "open_meteo",
  "weather_cache_ttl_seconds": 600,
  "weather_prefetch_on_start": true,
  "always_on_time_context": true,
  "llm_stream": true,

  "model": "llama3.2:3b",
  "ollama_url": "http://localhost:11434/api/chat",
  "llm_options": {
    "stream": false,
    "options": {
      "temperature": 0.0,
      "top_p": 0.9,
      "num_predict": 150
    }
  },

  "partial_ttl": 30,
  "final_ttl": 60,
  "partial_save_threshold": 200,
  "llm_timeout": 600,
  "auto_run_plugins": true,
  "preferred_plugins": {
    "turn_on_light": "automation_plugin",
    "turn_off_light": "automation_plugin"
  }
  ,
  "tts": {
    "enabled": true,
    "provider": "piper",
    "streaming": true,
    "streaming_output": true,
    "mode": "binary",
    "server_url": "http://localhost:5002/synthesize",
    "binary_cmd": ["piper", "--model", "./voices/amy_medium/en_US-amy-medium.onnx", "--output-file", "{out}", "{text}"],
    "headers": {},
    "output_dir": "/tmp",
    "playback": {
      "enabled": true,
      "preferred_player": "/usr/bin/aplay",
      "volume": 1.0,
      "queue": true
    }
  }
}